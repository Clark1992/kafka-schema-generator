{
  "name": "KafkaSchemaEvolutioner.Tests.Avro.SampleRebuiltEvent",
  "type": "record",
  "fields": [
    {
      "name": "Address",
      "type": {
        "name": "KafkaSchemaEvolutioner.Tests.Avro.SampleAddress",
        "type": "record",
        "fields": [
          {"name": "City", "type": "string"},
          {"name": "Id", "type": {"type": "string", "logicalType": "uuid"}},
          {"name": "NewCountry", "type": ["null", "string"], "default": null},
          {"name": "Street", "type": "string"}
        ]
      }
    },
    {
      "name": "Attachments",
      "type": {
        "type": "array",
        "items": {
          "name": "KafkaSchemaEvolutioner.Tests.Avro.SampleAttachment",
          "type": "record",
          "fields": [
            {"name": "FileName", "type": "string"},
            {"name": "Id", "type": {"type": "string", "logicalType": "uuid"}},
            {"name": "NewUrl", "type": ["null", "string"], "default": null}
          ]
        }
      }
    },
    {"name": "Description", "type": "string"},
    {"name": "Name", "type": "string"},
    {"name": "NewOccurredAt", "type": ["null", {"type": "long", "logicalType": "timestamp-millis"}], "default": null},
    {"name": "SampleId", "type": {"type": "string", "logicalType": "uuid"}},
    {"name": "Tags", "type": ["null", {"type": "array", "items": "string"}], "default": null}
  ]
}